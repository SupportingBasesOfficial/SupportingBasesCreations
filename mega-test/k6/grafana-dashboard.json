{
  "title": "K6 Performance Dashboard",
  "panels": [
    {
      "title": "Requests per Second",
      "type": "graph",
      "targets": [
        {
          "expr": "rate(k6_http_reqs_total[5m])"
        }
      ]
    },
    {
      "title": "Response Time",
      "type": "graph",
      "targets": [
        {
          "expr": "k6_http_req_duration_seconds{quantile=\"0.95\"}"
        }
      ]
    },
    {
      "title": "Error Rate",
      "type": "stat",
      "targets": [
        {
          "expr": "rate(k6_http_req_failed_total[5m])"
        }
      ]
    }
  ]
}