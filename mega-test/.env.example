# mega-tech-platform Environment Configuration
# Copy this file to .env.local and fill in your values

## Application
NODE_ENV=development
NEXT_PUBLIC_APP_NAME=mega-tech-platform
NEXT_PUBLIC_APP_URL=http://localhost:3000

## Database
DATABASE_URL=postgresql://user:password@localhost:5432/mega-tech-platform

## NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-random-secret-here-min-32-chars

## Authentication Providers
# Uncomment and configure the providers you want to use

# Credentials (built-in, no config needed)

# Oauth Google
# Google OAuth 2.0 authentication
# From Google Cloud Console > Credentials
GOOGLE_CLIENT_ID=
# From Google Cloud Console > Credentials
GOOGLE_CLIENT_SECRET=
# 
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback/google

# Stripe
# Stripe payment processing
# From Stripe Dashboard > Developers > API keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# From Stripe Dashboard > Developers > API keys
STRIPE_SECRET_KEY=
# From Stripe Dashboard > Developers > Webhooks
STRIPE_WEBHOOK_SECRET=

# Sentry
# Sentry error monitoring
# From Sentry Dashboard > Project Settings > Client Keys (DSN)
SENTRY_DSN=
# For source maps upload (optional)
SENTRY_AUTH_TOKEN=

## Cache
REDIS_URL=redis://localhost:6379

## Monitoring (optional)
# SENTRY_DSN=
