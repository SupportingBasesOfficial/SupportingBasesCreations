# saas-platform - Local Development Environment

NODE_ENV=development
NEXTAUTH_SECRET=local-dev-secret-change-in-production
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/saas-platform_dev

GOOGLE_CLIENT_ID=your_clientId_here
GOOGLE_CLIENT_SECRET=your_clientSecret_here
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback/google

NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_publishableKey_here
STRIPE_SECRET_KEY=your_secretKey_here
STRIPE_WEBHOOK_SECRET=your_webhookSecret_here

SENTRY_DSN=your_dsn_here
SENTRY_AUTH_TOKEN=your_authToken_here
