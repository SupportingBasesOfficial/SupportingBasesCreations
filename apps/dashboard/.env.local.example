# ============================================================
# SBC ASP - Environment Variables
# ============================================================
# Copy this file to .env.local and fill in the values
# Or set these in Vercel: Project → Settings → Environment Variables
# ============================================================

# --- Supabase (OBRIGATÓRIO) ---
# Pegar em: https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_HERE

# --- Groq AI (OBRIGATÓRIO para AI Copilot) ---
# Grátis: https://console.groq.com → API Keys → Create
GROQ_API_KEY=

# --- Upstash Redis (IMPORTANTE para deploy logs + rate limiting) ---
# Grátis: https://console.upstash.com → Create Database → REST API
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- OAuth Apps (OPCIONAL - só se quiser botões "Connect") ---
# Sem estas, usuário cola tokens manualmente no Cloud Settings

# GitHub: https://github.com/settings/developers → New OAuth App
# Callback URL: http://localhost:3000/api/oauth/github/callback (dev)
#              https://SEU-DOMINIO/api/oauth/github/callback (prod)
NEXT_PUBLIC_GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# Vercel: https://vercel.com/dashboard/~/settings/integrations → Create
# Callback URL: http://localhost:3000/api/oauth/vercel/callback (dev)
#              https://SEU-DOMINIO/api/oauth/vercel/callback (prod)
NEXT_PUBLIC_VERCEL_OAUTH_CLIENT_ID=
VERCEL_OAUTH_CLIENT_SECRET=

# Supabase: https://supabase.com/dashboard/account/tokens → OAuth Apps
# Callback URL: http://localhost:3000/api/oauth/supabase/callback (dev)
#              https://SEU-DOMINIO/api/oauth/supabase/callback (prod)
NEXT_PUBLIC_SUPABASE_OAUTH_CLIENT_ID=
SUPABASE_OAUTH_CLIENT_SECRET=
