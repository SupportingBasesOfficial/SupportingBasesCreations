# Supabase Auth (dashboard authentication)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# OAuth Provider Credentials
# GitHub OAuth App: https://github.com/settings/developers
GITHUB_OAUTH_CLIENT_ID=Ov23liFH8qfQSEhGmJ8F
GITHUB_OAUTH_CLIENT_SECRET=

# Vercel OAuth App: https://vercel.com/dashboard/tokens
VERCEL_OAUTH_CLIENT_ID=
VERCEL_OAUTH_CLIENT_SECRET=

# Supabase OAuth App: https://supabase.com/dashboard/account/tokens
SUPABASE_OAUTH_CLIENT_ID=
SUPABASE_OAUTH_CLIENT_SECRET=

# Next.js — auto-set by Vercel, override only for custom domains
NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_VERCEL_URL=

# Upstash Redis (rate limiting, locks, KV)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Vercel Blob Storage (file storage)
BLOB_READ_WRITE_TOKEN=

# Vercel Edge Config (feature flags, config)
EDGE_CONFIG=

# Upstash QStash (serverless queue)
QSTASH_TOKEN=
QSTASH_CURRENT_URL=

# Sentry for error tracking
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
