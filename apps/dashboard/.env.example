# OAuth Provider Credentials
# GitHub OAuth App: https://github.com/settings/developers
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# Vercel OAuth App: https://vercel.com/dashboard/tokens
VERCEL_OAUTH_CLIENT_ID=
VERCEL_OAUTH_CLIENT_SECRET=

# Supabase OAuth App: https://supabase.com/dashboard/account/tokens
SUPABASE_OAUTH_CLIENT_ID=
SUPABASE_OAUTH_CLIENT_SECRET=

# Supabase Platform (for auth + cloud persistence)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Upstash Redis (rate limiting, KV store, plugin loader)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Upstash QStash (serverless event queue)
QSTASH_TOKEN=

# Vercel Blob Storage (file storage)
BLOB_READ_WRITE_TOKEN=

# Next.js
NEXT_PUBLIC_APP_URL=http://localhost:3002
